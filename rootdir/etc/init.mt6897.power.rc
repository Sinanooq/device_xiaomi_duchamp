on early-init
    # boot perf. tune
    write /sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq 1800000
    write /sys/devices/system/cpu/cpufreq/policy4/scaling_min_freq 1800000
    write /sys/devices/system/cpu/cpufreq/policy7/scaling_min_freq 1800000
    write /sys/class/devfreq/mtk-dvfsrc-devfreq/userspace/set_freq 5500000000

on charger
    write /sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq 0
    write /sys/devices/system/cpu/cpufreq/policy4/scaling_min_freq 0
    write /sys/devices/system/cpu/cpufreq/policy7/scaling_min_freq 0
    write /sys/class/devfreq/mtk-dvfsrc-devfreq/userspace/set_freq 0

on init
    write /sys/block/sda/queue/scheduler mq-deadline

    # Set sugov_ext as cpu frequency governor (MTK custom schedutil)
    write /sys/devices/system/cpu/cpufreq/policy0/scaling_governor sugov_ext
    write /sys/devices/system/cpu/cpufreq/policy4/scaling_governor sugov_ext
    write /sys/devices/system/cpu/cpufreq/policy7/scaling_governor sugov_ext

    # Set menu as cpu idle governor (confirmed from device)
    write /sys/devices/system/cpu/cpuidle/current_governor menu

    # update cpus for cpuset cgroup
    write /dev/cpuset/background/cpus 0-3
    write /dev/cpuset/camera-daemon/cpus 0-7
    write /dev/cpuset/foreground/cpus 0-6
    write /dev/cpuset/foreground_window/cpus 0-6
    write /dev/cpuset/restricted/cpus 0-3
    write /dev/cpuset/system-background/cpus 0-3
    write /dev/cpuset/top-app/cpus 0-7

    # adjust PCP high level
    write /proc/sys/vm/percpu_pagelist_high_fraction 430

    # proactive compaction (confirmed from device: 20)
    write /proc/sys/vm/compaction_proactiveness 20

    # Make foreground and background I/O priority different. none-to-rt was
    # introduced in kernel 5.14. promote-to-rt was introduced in kernel 6.5.
    # Write none-to-rt first and promote-to-rt next to support both older and
    # newer kernel versions.
    write /dev/blkio/blkio.prio.class none-to-rt
    write /dev/blkio/blkio.prio.class promote-to-rt

on post-fs-data
    # Disable watermark boost
    write /proc/sys/vm/watermark_boost_factor 0

    # multi-gen LRU (disabled on device: 0x0000)
    write /sys/kernel/mm/lru_gen/enabled 0x0000

    # zram
    write /sys/block/zram0/comp_algorithm lz4
    # page-cluster=0: UFS için swap'ta tek sayfa oku — SSD benzeri depolama için optimal
    # (HDD için 3 mantıklı, UFS için 0 daha az gecikme)
    write /proc/sys/vm/page-cluster 0
    write /proc/sys/vm/swappiness 80
    write /sys/kernel/mm/swap/vma_ra_enabled true

    # boot time fs tune (UFS: sda/sdb/sdc — mmcblk0 yok)
    write /sys/block/sda/queue/iostats 0
    write /sys/block/sdb/queue/iostats 0
    write /sys/block/sdc/queue/iostats 0
    write /sys/block/sda/queue/nr_requests 256
    write /sys/block/sdb/queue/nr_requests 256
    write /sys/block/sdc/queue/nr_requests 256
    # read_ahead_kb: boot sırasında büyük okuma penceresi — daha hızlı uygulama yükleme
    write /sys/block/sda/queue/read_ahead_kb 2048
    write /sys/block/sdb/queue/read_ahead_kb 2048
    write /sys/block/sdc/queue/read_ahead_kb 2048

    # boot perf. tune
    write /dev/cpuctl/rt/cpu.uclamp.min 100
    write /dev/cpuctl/rt/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/system-background/cpu.uclamp.min 100
    write /dev/cpuctl/system-background/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/foreground/cpu.uclamp.min 100
    write /dev/cpuctl/foreground/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/foreground_window/cpu.uclamp.min 100
    write /dev/cpuctl/foreground_window/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/top-app/cpu.uclamp.min 100
    write /dev/cpuctl/top-app/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/background/cpu.uclamp.min 100
    write /dev/cpuctl/background/cpu.uclamp.latency_sensitive 1

on property:sys.boot_completed=1
    # end boot time fs tune
    write /sys/block/sda/queue/nr_requests 64
    write /sys/block/sdb/queue/nr_requests 64
    write /sys/block/sdc/queue/nr_requests 64
    # read_ahead_kb: boot sonrası normal değere düşür (UFS için 128KB yeterli)
    write /sys/block/sda/queue/read_ahead_kb 128
    write /sys/block/sdb/queue/read_ahead_kb 128
    write /sys/block/sdc/queue/read_ahead_kb 128
    # iostats yeniden aç (boot sonrası normal mod)
    write /sys/block/sda/queue/iostats 1
    write /sys/block/sdb/queue/iostats 1
    write /sys/block/sdc/queue/iostats 1

    # zram writeback
    setprop persist.sys.zram_enabled 1
    swapon_all /vendor/etc/fstab.mt6897

    # Adjust watermark level (confirmed from device: 50)
    write /proc/sys/vm/watermark_scale_factor 50

    # min_free_kbytes: 12MB — kernel'in her zaman tuttuğu minimum boş bellek
    # Çok düşük değer OOM'a, çok yüksek değer bellek israfına neden olur
    write /proc/sys/vm/min_free_kbytes 12288

    # restore boot perf. tune — min frekansları sıfırla, max frekansları tam değere çek
    write /sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq 0
    write /sys/devices/system/cpu/cpufreq/policy4/scaling_min_freq 0
    write /sys/devices/system/cpu/cpufreq/policy7/scaling_min_freq 0
    write /sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq 2200000
    write /sys/devices/system/cpu/cpufreq/policy4/scaling_max_freq 3200000
    write /sys/devices/system/cpu/cpufreq/policy7/scaling_max_freq 3350000
    write /sys/class/devfreq/mtk-dvfsrc-devfreq/userspace/set_freq 0

    # Utilization Clamping
    # Tuning
    write /proc/sys/kernel/sched_util_clamp_min_rt_default 0
    write /proc/sys/kernel/sched_util_clamp_min 0

    # sugov_ext rate limits (up/down = 1000us, confirmed from device)
    write /sys/devices/system/cpu/cpufreq/policy0/sugov_ext/up_rate_limit_us 1000
    write /sys/devices/system/cpu/cpufreq/policy0/sugov_ext/down_rate_limit_us 1000
    write /sys/devices/system/cpu/cpufreq/policy4/sugov_ext/up_rate_limit_us 1000
    write /sys/devices/system/cpu/cpufreq/policy4/sugov_ext/down_rate_limit_us 1000
    write /sys/devices/system/cpu/cpufreq/policy7/sugov_ext/up_rate_limit_us 1000
    write /sys/devices/system/cpu/cpufreq/policy7/sugov_ext/down_rate_limit_us 1000

    # rt
    write /dev/cpuctl/rt/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/rt/cpu.uclamp.max max
    write /dev/cpuctl/rt/cpu.uclamp.min 0
    write /dev/cpuctl/rt/cpu.shares 20480

    # system
    write /dev/cpuctl/system/cpu.shares 20480

    # system-background
    write /dev/cpuctl/system-background/cpu.uclamp.latency_sensitive 0
    write /dev/cpuctl/system-background/cpu.uclamp.max 60
    write /dev/cpuctl/system-background/cpu.uclamp.min 0
    write /dev/cpuctl/system-background/cpu.shares 1024

    # background
    write /dev/cpuctl/background/cpu.uclamp.latency_sensitive 0
    write /dev/cpuctl/background/cpu.uclamp.max 40
    write /dev/cpuctl/background/cpu.uclamp.min 0
    write /dev/cpuctl/background/cpu.shares 1024

    # foreground
    write /dev/cpuctl/foreground/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/foreground/cpu.uclamp.max 80
    write /dev/cpuctl/foreground/cpu.uclamp.min 0
    write /dev/cpuctl/foreground/cpu.shares 20480

    # foreground_window
    write /dev/cpuctl/foreground_window/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/foreground_window/cpu.uclamp.max 80
    write /dev/cpuctl/foreground_window/cpu.uclamp.min 0
    write /dev/cpuctl/foreground_window/cpu.shares 20480

    # top-app
    write /dev/cpuctl/top-app/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/top-app/cpu.uclamp.max max
    write /dev/cpuctl/top-app/cpu.uclamp.min 0
    write /dev/cpuctl/top-app/cpu.shares 20480

    # nnapi-hal
    write /dev/cpuctl/nnapi-hal/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/nnapi-hal/cpu.uclamp.max max
    write /dev/cpuctl/nnapi-hal/cpu.uclamp.min 75
    write /dev/cpuctl/nnapi-hal/cpu.shares 20480

    # camera-daemon
    write /dev/cpuctl/camera-daemon/cpu.uclamp.latency_sensitive 1
    write /dev/cpuctl/camera-daemon/cpu.uclamp.max max
    write /dev/cpuctl/camera-daemon/cpu.uclamp.min 60
    write /dev/cpuctl/camera-daemon/cpu.shares 20480

    # dex2oat
    write /dev/cpuctl/dex2oat/cpu.uclamp.latency_sensitive 0
    write /dev/cpuctl/dex2oat/cpu.uclamp.max 60
    write /dev/cpuctl/dex2oat/cpu.uclamp.min 0
    write /dev/cpuctl/dex2oat/cpu.shares 512
    # dex2oat cpuset: sadece küçük core'lar (0-3) — arka planda derleme foreground'u etkilemesin
    write /dev/cpuset/dex2oat/cpus 0-3

    # start cpuqos
    write /sys/devices/system/cpu/cpuqos/cpuqos_boot_complete 1

    # core_ctl offline throttle (confirmed from device: 100ms)
    write /sys/devices/system/cpu/cpu0/core_ctl/offline_throttle_ms 100
    write /sys/devices/system/cpu/cpu4/core_ctl/offline_throttle_ms 100
    write /sys/devices/system/cpu/cpu7/core_ctl/offline_throttle_ms 100

    # Enable PowerHAL hint processing
    setprop vendor.powerhal.init 1

    # FPSGO — Frame Per Second GO (MTK FPS-based CPU/GPU boost system)
    # Enable FPSGO (confirmed active on device)
    write /sys/kernel/fpsgo/common/fpsgo_enable 1

    # FPSGO FBT (Frame Budget Tracker) — ceiling enabled
    write /sys/kernel/fpsgo/fbt/enable_ceiling 1

    # FPSGO FBT — thermal throttle enable
    write /sys/kernel/fpsgo/fbt/thrm_enable 1

    # FPSGO FSTB (Frame Stability) — self-controlled fps
    write /sys/kernel/fpsgo/fstb/fstb_self_ctrl_fps_enable 1

    # FPSGO FSTB — fps list (30/60/90/120/144/240)
    write /sys/kernel/fpsgo/fstb/fstb_fps_list "30 60 90 120 144 240"

    # FPSGO FSTB — margin mode (0=fixed, 1=dynamic)
    write /sys/kernel/fpsgo/fstb/margin_mode 1
    write /sys/kernel/fpsgo/fstb/margin_mode_gpu 1

    # FPSGO XGF — EMA2 enable
    write /sys/kernel/fpsgo/xgf/xgf_ema2_enable 1

    # GBE (Game Boost Engine) — enable
    write /sys/kernel/gbe/gbe_enable1 1
    write /sys/kernel/gbe/gbe_enable2 1

    # Mali GPU power policy (coarse_demand = dynamic, not always_on)
    write /sys/class/misc/mali0/device/power_policy coarse_demand

    # GED (GPU DVFS) — confirmed from device
    write /sys/kernel/ged/hal/dvfs_loading_mode 5
    write /sys/kernel/ged/hal/loading_base_dvfs_step 4
    write /sys/kernel/ged/hal/dvfs_margin_value 530
    write /sys/kernel/ged/hal/timer_base_dvfs_margin 30
    write /sys/kernel/ged/hal/loading_window_size 8
    write /sys/kernel/ged/hal/loading_stride_size 2
    write /sys/kernel/ged/hal/fallback_timing 210
    write /sys/kernel/ged/hal/fallback_interval 1
    write /sys/kernel/ged/hal/fallback_window_size 5
    write /sys/kernel/ged/hal/dvfs_workload_mode 5
    write /sys/kernel/ged/hal/fw_idle 1

    # Touch boost — enable
    write /proc/touch_boost/enable 1

    # PPM (Power Policy Manager) — policy status
    write /proc/ppm/policy_status "0 1"

    # CCI mode
    write /proc/cpufreq/cpufreq_cci_mode 0

    # Deep sleep — cpuidle ve MCDI (Multi-Core Deep Idle) aktif
    # menu governor zaten ayarlı, burada cpuidle enable edildiğinden emin oluyoruz
    write /proc/cpuidle/enable 1
    # MCDI state 1 = deep idle aktif (0 = disabled, 1 = enabled)
    write /proc/mcdi/state 1

service vendor.hwcomposer-3-2 /vendor/bin/hw/android.hardware.graphics.composer@3.2-service
    override
    class hal animation
    user system
    group graphics drmrpc
    capabilities SYS_NICE
    onrestart restart surfaceflinger
    task_profiles ProcessCapacityHigh HighPerformance
