soong_namespace {
    imports: [
        "hardware/xiaomi",
    ],
}

// ImsService vendor blob'da (vendor/xiaomi/duchamp) zaten tanımlı
// Burada tekrar tanımlamak MODULE.TARGET.APPS.ImsService duplicate hatasına neden oluyor

install_symlink {
    name: "vendor_mdota_symlink",
    vendor: true,
    installed_location: "etc/mdota",
    symlink_target: "/mnt/vendor/mdota",
}
